# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://openboard_ai:openboard_ai@localhost:5436/openboard_ai

# Better Auth — session signing secret (required for accounts/login).
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Base URL the API serves auth from. The web app proxies /api here in dev.
BETTER_AUTH_URL=http://localhost:3001
# Optional: extra trusted origins (comma-separated) for deployed environments,
# e.g. https://app.example.com
# BETTER_AUTH_TRUSTED_ORIGINS=

# GitHub OAuth (optional — enables "Sign in with GitHub" when both are set).
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL (dev): http://localhost:3001/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OpenRouter API key is now configured per-user in the app UI — no env var required.
# Each user enters their own key via the in-app setup dialog (stored in localStorage,
# sent as X-OpenRouter-Key on every AI request). Get a key at https://openrouter.ai/keys

# Optional: app metadata sent to OpenRouter (HTTP-Referer / X-Title) for usage attribution.
OPENROUTER_APP_NAME=openboard-ai
OPENROUTER_APP_URL=http://localhost:5173

# Optional: override the image model. Defaults to google/gemini-2.5-flash-image
# (cheap, fast, reliable). Other options: openai/gpt-5-image (higher quality,
# ~30x cost), google/gemini-3-pro-image-preview, openai/gpt-5.4-image-2 (newest
# but currently returns empty bodies intermittently — avoid).
# OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# Optional: override the video model. Defaults to google/veo-3.1-fast (~$0.12/sec
# @ 1080p+audio). Switch to google/veo-3.1 for premium quality (~$0.40/sec, but
# requires a higher account balance for OpenRouter's upfront credit reservation)
# or google/veo-3.1-lite for cheapest (~$0.08/sec).
# OPENROUTER_VIDEO_MODEL=google/veo-3.1-fast

# API server port (web proxies /api -> here)
API_PORT=3001

# tldraw license key — loaded at build time into the web bundle.
# Get one at https://tldraw.dev/#pricing
VITE_TLDRAW_LICENSE_KEY=

# Optional: PostHog project key for anonymous usage analytics. When unset, the
# analytics layer is a silent no-op (no network requests, nothing tracked).
# Get a key at https://us.posthog.com → Project settings → Project ID.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
